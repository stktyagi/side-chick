ruct gpio_chip *gc, unsigned int offset,\n60: \t\t\t\t     int value)\n61: {\n62: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n63: \tint ret;\n64: \n65: \tret = mux_control_select(priv->mux, offset);\n66: \tif (ret)\n67: \t\treturn ret;\n68: \n69: \tret = gpiod_direction_output(priv->gpio, value);\n70: \tif (ret) {\n71: \t\tmux_control_deselect(priv->mux);\n72: \t\treturn ret;\n73: \t}\n74: \n75: \tpriv->dir_cache[offset] = 0;\n76: \tpriv->val_cache[offset] = value;\n77: \n78: \tmux_control_deselect(priv->mux);\n79: \n80: \treturn 0;\n81: }\n82: \n83: static int gpio_mux_get(struct gpio_chip *gc, unsigned int offset)\n84: {\n85: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n86: \tint val;\n87: \n88: \tif (!priv->dir_cache[offset])\n89: \t\treturn priv->val_cache[offset];\n90: \n91: \tif (mux_control_select(priv->mux, offset))\n92: \t\treturn 0;\n93: \n94: \tif (gpiod_direction_input(priv->gpio)) {\n95: \t\tmux_control_deselect(priv->mux);\n96: \t\treturn 0;\n97: \t}\n98: \n99: \tval = gpiod_get_value_cansleep(priv->gpio);\n100: \n101: \tmux_control_deselect(priv->mux);\n102: \n103: \treturn val;\n104: }\n105: \n106: static void gpio_mux_set(struct gpio_chip *gc, unsigned int offset, int value)\n107: {\n108: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n109: \n110: \tpriv->val_cache[offset] = value;\n111: \n112: \tif (priv->dir_cache[offset])\n113: \t\treturn;\n114: \n115: \tif (mux_control_select(priv->mux, offset))\n116: \t\treturn;\n117: \n118: \tgpiod_direction_output(priv->gpio, value);\n119: \n120: \tmux_control_deselect(priv->mux);\n121: }\n122: \n123: static int gpio_mux_probe(struct platform_device *pdev)\n124: {\n125: \tstruct device *dev = &pdev->dev;\n126: \tstruct gpio_mux_priv *priv;\n127: \tunsigned int nstates, i;\n128: \n129: \tpriv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);\n130: \tif (!priv)\n131: \t\treturn -ENOMEM;\n132: \n133: \tpriv->mux = devm_mux_control_get(dev, NULL);\n134: \tif (IS_ERR(priv->mux))\n135: \t\