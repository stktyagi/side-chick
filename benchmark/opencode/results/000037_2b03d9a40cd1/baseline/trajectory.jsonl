{"type":"tool_use","timestamp":1782186918174,"sessionID":"ses_10d67ce83ffeqFdCHSu0VlDLX8","part":{"type":"tool","tool":"read","callID":"call_00_EkW6vuG2sxlkTkJr5e8i0006","state":{"status":"completed","input":{"filePath":"/tmp/tmp.R6TG01uHm4/drivers/gpio/gpio-mux.c"},"output":"<path>/tmp/tmp.R6TG01uHm4/drivers/gpio/gpio-mux.c</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: GPL-2.0\n2: /*\n3:  * GPIO mux-controlled GPIO driver\n4:  *\n5:  * Copyright (C) 2024\n6:  *\n7:  * Maps multiple virtual GPIOs to a single real GPIO line via a\n8:  * multiplexer controller. The mux selects which virtual line is\n9:  * active for GPIO operations.\n10:  */\n11: \n12: #include <linux/err.h>\n13: #include <linux/gpio/consumer.h>\n14: #include <linux/gpio/driver.h>\n15: #include <linux/module.h>\n16: #include <linux/mod_devicetable.h>\n17: #include <linux/mux/consumer.h>\n18: #include <linux/platform_device.h>\n19: #include <linux/slab.h>\n20: \n21: struct gpio_mux_priv {\n22: \tstruct gpio_chip gc;\n23: \tstruct mux_control *mux;\n24: \tstruct gpio_desc *gpio;\n25: \tunsigned int *dir_cache;\n26: \tint *val_cache;\n27: };\n28: \n29: static int gpio_mux_get_direction(struct gpio_chip *gc, unsigned int offset)\n30: {\n31: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n32: \n33: \treturn priv->dir_cache[offset] ? GPIO_LINE_DIRECTION_IN\n34: \t\t\t\t       : GPIO_LINE_DIRECTION_OUT;\n35: }\n36: \n37: static int gpio_mux_direction_input(struct gpio_chip *gc, unsigned int offset)\n38: {\n39: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n40: \tint ret;\n41: \n42: \tret = mux_control_select(priv->mux, offset);\n43: \tif (ret)\n44: \t\treturn ret;\n45: \n46: \tret = gpiod_direction_input(priv->gpio);\n47: \tif (ret) {\n48: \t\tmux_control_deselect(priv->mux);\n49: \t\treturn ret;\n50: \t}\n51: \n52: \tpriv->dir_cache[offset] = 1;\n53: \n54: \tmux_control_deselect(priv->mux);\n55: \n56: \treturn 0;\n57: }\n58: \n59: static int gpio_mux_direction_output(struct gpio_chip *gc, unsigned int offset,\n60: \t\t\t\t     int value)\n61: {\n62: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n63: \tint ret;\n64: \n65: \tret = mux_control_select(priv->mux, offset);\n66: \tif (ret)\n67: \t\treturn ret;\n68: \n69: \tret = gpiod_direction_output(priv->gpio, value);\n70: \tif (ret) {\n71: \t\tmux_control_deselect(priv->mux);\n72: \t\treturn ret;\n73: \t}\n74: \n75: \tpriv->dir_cache[offset] = 0;\n76: \tpriv->val_cache[offset] = value;\n77: \n78: \tmux_control_deselect(priv->mux);\n79: \n80: \treturn 0;\n81: }\n82: \n83: static int gpio_mux_get(struct gpio_chip *gc, unsigned int offset)\n84: {\n85: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n86: \tint val;\n87: \n88: \tif (!priv->dir_cache[offset])\n89: \t\treturn priv->val_cache[offset];\n90: \n91: \tif (mux_control_select(priv->mux, offset))\n92: \t\treturn 0;\n93: \n94: \tgpiod_direction_input(priv->gpio);\n95: \tval = gpiod_get_value_cansleep(priv->gpio);\n96: \n97: \tmux_control_deselect(priv->mux);\n98: \n99: \treturn val;\n100: }\n101: \n102: static void gpio_mux_set(struct gpio_chip *gc, unsigned int offset, int value)\n103: {\n104: \tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n105: \n106: \tpriv->val_cache[offset] = value;\n107: \n108: \tif (priv->dir_cache[offset])\n109: \t\treturn;\n110: \n111: \tif (mux_control_select(priv->mux, offset))\n112: \t\treturn;\n113: \n114: \tgpiod_direction_output(priv->gpio, value);\n115: \n116: \tmux_control_deselect(priv->mux);\n117: }\n118: \n119: static int gpio_mux_probe(struct platform_device *pdev)\n120: {\n121: \tstruct device *dev = &pdev->dev;\n122: \tstruct gpio_mux_priv *priv;\n123: \tunsigned int nstates, i;\n124: \n125: \tpriv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);\n126: \tif (!priv)\n127: \t\treturn -ENOMEM;\n128: \n129: \tpriv->mux = devm_mux_control_get(dev, NULL);\n130: \tif (IS_ERR(priv->mux))\n131: \t\treturn dev_err_probe(dev, PTR_ERR(priv->mux),\n132: \t\t\t\t     \"failed to get mux\\n\");\n133: \n134: \tpriv->gpio = devm_gpiod_get(dev, NULL, GPIOD_ASIS);\n135: \tif (IS_ERR(priv->gpio))\n136: \t\treturn dev_err_probe(dev, PTR_ERR(priv->gpio),\n137: \t\t\t\t     \"failed to get gpio\\n\");\n138: \n139: \tnstates = mux_control_states(priv->mux);\n140: \tif (nstates < 2)\n141: \t\treturn dev_err_probe(dev, -EINVAL,\n142: \t\t\t\t     \"need at least 2 mux states\\n\");\n143: \n144: \tpriv->dir_cache = devm_kcalloc(dev, nstates, sizeof(*priv->dir_cache),\n145: \t\t\t\t       GFP_KERNEL);\n146: \tif (!priv->dir_cache)\n147: \t\treturn -ENOMEM;\n148: \n149: \tpriv->val_cache = devm_kcalloc(dev, nstates, sizeof(*priv->val_cache),\n150: \t\t\t\t       GFP_KERNEL);\n151: \tif (!priv->val_cache)\n152: \t\treturn -ENOMEM;\n153: \n154: \tfor (i = 0; i < nstates; i++)\n155: \t\tpriv->dir_cache[i] = 1;\n156: \n157: \tpriv->gc.label = dev_name(dev);\n158: \tpriv->gc.owner = THIS_MODULE;\n159: \tpriv->gc.parent = dev;\n160: \tpriv->gc.base = -1;\n161: \tpriv->gc.ngpio = nstates;\n162: \tpriv->gc.can_sleep = true;\n163: \tpriv->gc.get_direction = gpio_mux_get_direction;\n164: \tpriv->gc.direction_input = gpio_mux_direction_input;\n165: \tpriv->gc.direction_output = gpio_mux_direction_output;\n166: \tpriv->gc.get = gpio_mux_get;\n167: \tpriv->gc.set = gpio_mux_set;\n168: \n169: \tplatform_set_drvdata(pdev, priv);\n170: \n171: \treturn devm_gpiochip_add_data(dev, &priv->gc, priv);\n172: }\n173: \n174: static const struct of_device_id gpio_mux_of_match[] = {\n175: \t{ .compatible = \"gpio-mux-controlled\", },\n176: \t{ /* sentinel */ }\n177: };\n178: MODULE_DEVICE_TABLE(of, gpio_mux_of_match);\n179: \n180: static struct platform_driver gpio_mux_driver = {\n181: \t.driver = {\n182: \t\t.name = \"gpio-mux-controlled\",\n183: \t\t.of_match_table = gpio_mux_of_match,\n184: \t},\n185: \t.probe = gpio_mux_probe,\n186: };\n187: module_platform_driver(gpio_mux_driver);\n188: \n189: MODULE_LICENSE(\"GPL v2\");\n190: MODULE_AUTHOR(\"OpenCode\");\n191: MODULE_DESCRIPTION(\"GPIO mux-controlled GPIO driver\");\n\n(End of file - total 191 lines)\n</content>","metadata":{"preview":"// SPDX-License-Identifier: GPL-2.0\n/*\n * GPIO mux-controlled GPIO driver\n *\n * Copyright (C) 2024\n *\n * Maps multiple virtual GPIOs to a single real GPIO line via a\n * multiplexer controller. The mux selects which virtual line is\n * active for GPIO operations.\n */\n\n#include <linux/err.h>\n#include <linux/gpio/consumer.h>\n#include <linux/gpio/driver.h>\n#include <linux/module.h>\n#include <linux/mod_devicetable.h>\n#include <linux/mux/consumer.h>\n#include <linux/platform_device.h>\n#include <linux/slab.h>\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/tmp/tmp.R6TG01uHm4/drivers/gpio/gpio-mux.c","text":"// SPDX-License-Identifier: GPL-2.0\n/*\n * GPIO mux-controlled GPIO driver\n *\n * Copyright (C) 2024\n *\n * Maps multiple virtual GPIOs to a single real GPIO line via a\n * multiplexer controller. The mux selects which virtual line is\n * active for GPIO operations.\n */\n\n#include <linux/err.h>\n#include <linux/gpio/consumer.h>\n#include <linux/gpio/driver.h>\n#include <linux/module.h>\n#include <linux/mod_devicetable.h>\n#include <linux/mux/consumer.h>\n#include <linux/platform_device.h>\n#include <linux/slab.h>\n\nstruct gpio_mux_priv {\n\tstruct gpio_chip gc;\n\tstruct mux_control *mux;\n\tstruct gpio_desc *gpio;\n\tunsigned int *dir_cache;\n\tint *val_cache;\n};\n\nstatic int gpio_mux_get_direction(struct gpio_chip *gc, unsigned int offset)\n{\n\tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n\n\treturn priv->dir_cache[offset] ? GPIO_LINE_DIRECTION_IN\n\t\t\t\t       : GPIO_LINE_DIRECTION_OUT;\n}\n\nstatic int gpio_mux_direction_input(struct gpio_chip *gc, unsigned int offset)\n{\n\tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n\tint ret;\n\n\tret = mux_control_select(priv->mux, offset);\n\tif (ret)\n\t\treturn ret;\n\n\tret = gpiod_direction_input(priv->gpio);\n\tif (ret) {\n\t\tmux_control_deselect(priv->mux);\n\t\treturn ret;\n\t}\n\n\tpriv->dir_cache[offset] = 1;\n\n\tmux_control_deselect(priv->mux);\n\n\treturn 0;\n}\n\nstatic int gpio_mux_direction_output(struct gpio_chip *gc, unsigned int offset,\n\t\t\t\t     int value)\n{\n\tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n\tint ret;\n\n\tret = mux_control_select(priv->mux, offset);\n\tif (ret)\n\t\treturn ret;\n\n\tret = gpiod_direction_output(priv->gpio, value);\n\tif (ret) {\n\t\tmux_control_deselect(priv->mux);\n\t\treturn ret;\n\t}\n\n\tpriv->dir_cache[offset] = 0;\n\tpriv->val_cache[offset] = value;\n\n\tmux_control_deselect(priv->mux);\n\n\treturn 0;\n}\n\nstatic int gpio_mux_get(struct gpio_chip *gc, unsigned int offset)\n{\n\tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n\tint val;\n\n\tif (!priv->dir_cache[offset])\n\t\treturn priv->val_cache[offset];\n\n\tif (mux_control_select(priv->mux, offset))\n\t\treturn 0;\n\n\tgpiod_direction_input(priv->gpio);\n\tval = gpiod_get_value_cansleep(priv->gpio);\n\n\tmux_control_deselect(priv->mux);\n\n\treturn val;\n}\n\nstatic void gpio_mux_set(struct gpio_chip *gc, unsigned int offset, int value)\n{\n\tstruct gpio_mux_priv *priv = gpiochip_get_data(gc);\n\n\tpriv->val_cache[offset] = value;\n\n\tif (priv->dir_cache[offset])\n\t\treturn;\n\n\tif (mux_control_select(priv->mux, offset))\n\t\treturn;\n\n\tgpiod_direction_output(priv->gpio, value);\n\n\tmux_control_deselect(priv->mux);\n}\n\nstatic int gpio_mux_probe(struct platform_device *pdev)\n{\n\tstruct device *dev = &pdev->dev;\n\tstruct gpio_mux_priv *priv;\n\tunsigned int nstates, i;\n\n\tpriv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);\n\tif (!priv)\n\t\treturn -ENOMEM;\n\n\tpriv->mux = devm_mux_control_get(dev, NULL);\n\tif (IS_ERR(priv->mux))\n\t\treturn dev_err_probe(dev, PTR_ERR(priv->mux),\n\t\t\t\t     \"failed to get mux\\n\");\n\n\tpriv->gpio = devm_gpiod_get(dev, NULL, GPIOD_ASIS);\n\tif (IS_ERR(priv->gpio))\n\t\treturn dev_err_probe(dev, PTR_ERR(priv->gpio),\n\t\t\t\t     \"failed to get gpio\\n\");\n\n\tnstates = mux_control_states(priv->mux);\n\tif (nstates < 2)\n\t\treturn dev_err_probe(dev, -EINVAL,\n\t\t\t\t     \"need at least 2 mux states\\n\");\n\n\tpriv->dir_cache = devm_kcalloc(dev, nstates, sizeof(*priv->dir_cache),\n\t\t\t\t       GFP_KERNEL);\n\tif (!priv->dir_cache)\n\t\treturn -ENOMEM;\n\n\tpriv->val_cache = devm_kcalloc(dev, nstates, sizeof(*priv->val_cache),\n\t\t\t\t       GFP_KERNEL);\n\tif (!priv->val_cache)\n\t\treturn -ENOMEM;\n\n\tfor (i = 0; i < nstates; i++)\n\t\tpriv->dir_cache[i] = 1;\n\n\tpriv->gc.label = dev_name(dev);\n\tpriv->gc.owner = THIS_MODULE;\n\tpriv->gc.parent = dev;\n\tpriv->gc.base = -1;\n\tpriv->gc.ngpio = nstates;\n\tpriv->gc.can_sleep = true;\n\tpriv->gc.get_direction = gpio_mux_get_direction;\n\tpriv->gc.direction_input = gpio_mux_direction_input;\n\tpriv->gc.direction_output = gpio_mux_direction_output;\n\tpriv->gc.get = gpio_mux_get;\n\tpriv->gc.set = gpio_mux_set;\n\n\tplatform_set_drvdata(pdev, priv);\n\n\treturn devm_gpiochip_add_data(dev, &priv->gc, priv);\n}\n\nstatic const struct of_device_id gpio_mux_of_match[] = {\n\t{ .compatible = \"gpio-mux-controlled\", },\n\t{ /* sentinel */ }\n};\nMODULE_DEVICE_TABLE(of, gpio_mux_of_match);\n\nstatic struct platform_driver gpio_mux_driver = {\n\t.driver = {\n\t\t.name = \"gpio-mux-controlled\",\n\t\t.of_match_table = gpio_mux_of_match,\n\t},\n\t.probe = gpio_mux_probe,\n};\nmodule_platform_driver(gpio_mux_driver);\n\nMODULE_LICENSE(\"GPL v2\");\nMODULE_AUTHOR(\"OpenCode\");\nMODULE_DESCRIPTION(\"GPIO mux-controlled GPIO driver\");","lineStart":1,"lineEnd":191,"totalLines":191,"truncated":false}},"title":"tmp/tmp.R6TG01uHm4/drivers/gpio/gpio-mux.c","time":{"start":1782186918166,"end":1782186918172}},"id":"prt_ef29e4036001AsJ40HwZdWX0dL","sessionID":"ses_10d67ce83ffeqFdCHSu0VlDLX8","messageID":"msg_ef29e07dc001nxYAmxpbwEraAt"}}
