{"type":"tool_use","timestamp":1782186721277,"sessionID":"ses_10d73caccffeJObP2i94PboqoZ","part":{"type":"tool","tool":"read","callID":"call_00_gbyCbKG5kiYkqxymZxNJ1467","state":{"status":"completed","input":{"filePath":"/tmp/tmp.D9wEsGVJ2z/drivers/gpio/gpio-line-mux.c"},"output":"<path>/tmp/tmp.D9wEsGVJ2z/drivers/gpio/gpio-line-mux.c</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: GPL-2.0-only\n2: //\n3: // GPIO line mux - virtual GPIO chip using a mux controller\n4: //\n5: // Copyright (C) 2025 Authors\n6: //\n7: // Provides a gpiochip that uses a mux controller to select the active\n8: // virtual line for GPIO operations. Each virtual GPIO corresponds to\n9: // a mux state; the shared GPIO is accessed after switching the mux.\n10: \n11: #define DRV_NAME\t\"gpio-line-mux\"\n12: \n13: #include <linux/bitmap.h>\n14: #include <linux/device.h>\n15: #include <linux/err.h>\n16: #include <linux/gpio/consumer.h>\n17: #include <linux/gpio/driver.h>\n18: #include <linux/module.h>\n19: #include <linux/mutex.h>\n20: #include <linux/platform_device.h>\n21: #include <linux/property.h>\n22: \n23: #include <linux/mux/consumer.h>\n24: \n25: struct gpio_line_mux {\n26: \tstruct gpio_chip chip;\n27: \tstruct mux_control *mux;\n28: \tstruct gpio_desc *gpiod;\n29: \tstruct mutex lock;\n30: \tunsigned int ngpios;\n31: \tu32 *mux_states;\n32: \tunsigned long *values;\n33: \tunsigned long *dirs;\n34: };\n35: \n36: static struct gpio_line_mux *to_line_mux(struct gpio_chip *chip)\n37: {\n38: \treturn container_of(chip, struct gpio_line_mux, chip);\n39: }\n40: \n41: static int gpio_line_mux_get_direction(struct gpio_chip *chip,\n42: \t\t\t\t       unsigned int offset)\n43: {\n44: \tstruct gpio_line_mux *lm = to_line_mux(chip);\n45: \n46: \tguard(mutex)(&lm->lock);\n47: \n48: \tif (test_bit(offset, lm->dirs))\n49: \t\treturn GPIO_LINE_DIRECTION_IN;\n50: \n51: \treturn GPIO_LINE_DIRECTION_OUT;\n52: }\n53: \n54: static int gpio_line_mux_direction_input(struct gpio_chip *chip,\n55: \t\t\t\t\t unsigned int offset)\n56: {\n57: \tstruct gpio_line_mux *lm = to_line_mux(chip);\n58: \tint ret;\n59: \n60: \tguard(mutex)(&lm->lock);\n61: \n62: \tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n63: \tif (ret)\n64: \t\treturn ret;\n65: \n66: \tret = gpiod_direction_input(lm->gpiod);\n67: \tif (ret) {\n68: \t\tmux_control_deselect(lm->mux);\n69: \t\treturn ret;\n70: \t}\n71: \n72: \tset_bit(offset, lm->dirs);\n73: \tclear_bit(offset, lm->values);\n74: \n75: \treturn mux_control_deselect(lm->mux);\n76: }\n77: \n78: static int gpio_line_mux_direction_output(struct gpio_chip *chip,\n79: \t\t\t\t\t  unsigned int offset, int value)\n80: {\n81: \tstruct gpio_line_mux *lm = to_line_mux(chip);\n82: \tint ret;\n83: \n84: \tguard(mutex)(&lm->lock);\n85: \n86: \tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n87: \tif (ret)\n88: \t\treturn ret;\n89: \n90: \tret = gpiod_direction_output(lm->gpiod, value);\n91: \tif (ret) {\n92: \t\tmux_control_deselect(lm->mux);\n93: \t\treturn ret;\n94: \t}\n95: \n96: \tclear_bit(offset, lm->dirs);\n97: \t__assign_bit(offset, lm->values, value);\n98: \n99: \treturn mux_control_deselect(lm->mux);\n100: }\n101: \n102: static int gpio_line_mux_get(struct gpio_chip *chip, unsigned int offset)\n103: {\n104: \tstruct gpio_line_mux *lm = to_line_mux(chip);\n105: \tint ret, val;\n106: \n107: \tguard(mutex)(&lm->lock);\n108: \n109: \tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n110: \tif (ret)\n111: \t\treturn ret;\n112: \n113: \tif (!test_bit(offset, lm->dirs)) {\n114: \t\tret = gpiod_direction_input(lm->gpiod);\n115: \t\tif (ret) {\n116: \t\t\tmux_control_deselect(lm->mux);\n117: \t\t\treturn ret;\n118: \t\t}\n119: \t\tset_bit(offset, lm->dirs);\n120: \t}\n121: \n122: \tval = gpiod_get_value_cansleep(lm->gpiod);\n123: \n124: \tmux_control_deselect(lm->mux);\n125: \n126: \treturn val;\n127: }\n128: \n129: static int gpio_line_mux_set(struct gpio_chip *chip,\n130: \t\t\t     unsigned int offset, int value)\n131: {\n132: \tstruct gpio_line_mux *lm = to_line_mux(chip);\n133: \tint ret;\n134: \n135: \tguard(mutex)(&lm->lock);\n136: \n137: \tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n138: \tif (ret)\n139: \t\treturn ret;\n140: \n141: \tif (test_bit(offset, lm->dirs)) {\n142: \t\tret = gpiod_direction_output(lm->gpiod, value);\n143: \t\tif (ret) {\n144: \t\t\tmux_control_deselect(lm->mux);\n145: \t\t\treturn ret;\n146: \t\t}\n147: \t\tclear_bit(offset, lm->dirs);\n148: \t} else {\n149: \t\tgpiod_set_value_cansleep(lm->gpiod, value);\n150: \t}\n151: \n152: \t__assign_bit(offset, lm->values, value);\n153: \n154: \treturn mux_control_deselect(lm->mux);\n155: }\n156: \n157: static const struct gpio_chip gpio_line_mux_chip_template = {\n158: \t.label\t\t\t= DRV_NAME,\n159: \t.owner\t\t\t= THIS_MODULE,\n160: \t.get_direction\t\t= gpio_line_mux_get_direction,\n161: \t.direction_input\t= gpio_line_mux_direction_input,\n162: \t.direction_output\t= gpio_line_mux_direction_output,\n163: \t.get\t\t\t= gpio_line_mux_get,\n164: \t.set\t\t\t= gpio_line_mux_set,\n165: \t.base\t\t\t= -1,\n166: \t.can_sleep\t\t= true,\n167: };\n168: \n169: static int gpio_line_mux_probe(struct platform_device *pdev)\n170: {\n171: \tstruct device *dev = &pdev->dev;\n172: \tstruct gpio_line_mux *lm;\n173: \tint ret, count;\n174: \n175: \tlm = devm_kzalloc(dev, sizeof(*lm), GFP_KERNEL);\n176: \tif (!lm)\n177: \t\treturn -ENOMEM;\n178: \n179: \tcount = device_property_count_u32(dev, \"gpio-line-mux-states\");\n180: \tif (count < 1)\n181: \t\treturn dev_err_probe(dev, count < 0 ? count : -EINVAL,\n182: \t\t\t\t     \"missing or empty gpio-line-mux-states\\n\");\n183: \n184: \tlm->mux_states = devm_kmalloc_array(dev, count, sizeof(u32),\n185: \t\t\t\t\t    GFP_KERNEL);\n186: \tif (!lm->mux_states)\n187: \t\treturn -ENOMEM;\n188: \n189: \tret = device_property_read_u32_array(dev, \"gpio-line-mux-states\",\n190: \t\t\t\t\t     lm->mux_states, count);\n191: \tif (ret)\n192: \t\treturn dev_err_probe(dev, ret,\n193: \t\t\t\t     \"failed to read gpio-line-mux-states\\n\");\n194: \n195: \tlm->ngpios = count;\n196: \n197: \tlm->mux = devm_mux_control_get(dev, NULL);\n198: \tif (IS_ERR(lm->mux))\n199: \t\treturn dev_err_probe(dev, PTR_ERR(lm->mux),\n200: \t\t\t\t     \"failed to get mux controller\\n\");\n201: \n202: \tlm->gpiod = devm_gpiod_get(dev, \"muxed\", GPIOD_ASIS);\n203: \tif (IS_ERR(lm->gpiod))\n204: \t\treturn dev_err_probe(dev, PTR_ERR(lm->gpiod),\n205: \t\t\t\t     \"failed to get muxed GPIO\\n\");\n206: \n207: \tif (gpiod_cansleep(lm->gpiod))\n208: \t\tdev_info(dev, \"underlying GPIO can sleep\\n\");\n209: \n210: \tlm->values = devm_bitmap_zalloc(dev, lm->ngpios, GFP_KERNEL);\n211: \tif (!lm->values)\n212: \t\treturn -ENOMEM;\n213: \n214: \tlm->dirs = devm_bitmap_zalloc(dev, lm->ngpios, GFP_KERNEL);\n215: \tif (!lm->dirs)\n216: \t\treturn -ENOMEM;\n217: \n218: \tbitmap_fill(lm->dirs, lm->ngpios);\n219: \n220: \tmutex_init(&lm->lock);\n221: \n222: \tlm->chip = gpio_line_mux_chip_template;\n223: \tlm->chip.parent = dev;\n224: \tlm->chip.ngpio = lm->ngpios;\n225: \n226: \tret = devm_gpiochip_add_data(dev, &lm->chip, lm);\n227: \tif (ret)\n228: \t\treturn dev_err_probe(dev, ret, \"failed to add gpio chip\\n\");\n229: \n230: \tplatform_set_drvdata(pdev, lm);\n231: \n232: \treturn 0;\n233: }\n234: \n235: static const struct of_device_id gpio_line_mux_dt_ids[] = {\n236: \t{ .compatible = \"gpio-line-mux\" },\n237: \t{}\n238: };\n239: MODULE_DEVICE_TABLE(of, gpio_line_mux_dt_ids);\n240: \n241: static struct platform_driver gpio_line_mux_driver = {\n242: \t.probe\t= gpio_line_mux_probe,\n243: \t.driver\t= {\n244: \t\t.name\t\t= DRV_NAME,\n245: \t\t.of_match_table\t= gpio_line_mux_dt_ids,\n246: \t},\n247: };\n248: module_platform_driver(gpio_line_mux_driver);\n249: \n250: MODULE_AUTHOR(\"OpenCode\");\n251: MODULE_DESCRIPTION(\"GPIO line mux driver - virtual GPIOs via mux controller\");\n252: MODULE_LICENSE(\"GPL\");\n\n(End of file - total 252 lines)\n</content>","metadata":{"preview":"// SPDX-License-Identifier: GPL-2.0-only\n//\n// GPIO line mux - virtual GPIO chip using a mux controller\n//\n// Copyright (C) 2025 Authors\n//\n// Provides a gpiochip that uses a mux controller to select the active\n// virtual line for GPIO operations. Each virtual GPIO corresponds to\n// a mux state; the shared GPIO is accessed after switching the mux.\n\n#define DRV_NAME\t\"gpio-line-mux\"\n\n#include <linux/bitmap.h>\n#include <linux/device.h>\n#include <linux/err.h>\n#include <linux/gpio/consumer.h>\n#include <linux/gpio/driver.h>\n#include <linux/module.h>\n#include <linux/mutex.h>\n#include <linux/platform_device.h>","truncated":false,"loaded":[],"display":{"type":"file","path":"/tmp/tmp.D9wEsGVJ2z/drivers/gpio/gpio-line-mux.c","text":"// SPDX-License-Identifier: GPL-2.0-only\n//\n// GPIO line mux - virtual GPIO chip using a mux controller\n//\n// Copyright (C) 2025 Authors\n//\n// Provides a gpiochip that uses a mux controller to select the active\n// virtual line for GPIO operations. Each virtual GPIO corresponds to\n// a mux state; the shared GPIO is accessed after switching the mux.\n\n#define DRV_NAME\t\"gpio-line-mux\"\n\n#include <linux/bitmap.h>\n#include <linux/device.h>\n#include <linux/err.h>\n#include <linux/gpio/consumer.h>\n#include <linux/gpio/driver.h>\n#include <linux/module.h>\n#include <linux/mutex.h>\n#include <linux/platform_device.h>\n#include <linux/property.h>\n\n#include <linux/mux/consumer.h>\n\nstruct gpio_line_mux {\n\tstruct gpio_chip chip;\n\tstruct mux_control *mux;\n\tstruct gpio_desc *gpiod;\n\tstruct mutex lock;\n\tunsigned int ngpios;\n\tu32 *mux_states;\n\tunsigned long *values;\n\tunsigned long *dirs;\n};\n\nstatic struct gpio_line_mux *to_line_mux(struct gpio_chip *chip)\n{\n\treturn container_of(chip, struct gpio_line_mux, chip);\n}\n\nstatic int gpio_line_mux_get_direction(struct gpio_chip *chip,\n\t\t\t\t       unsigned int offset)\n{\n\tstruct gpio_line_mux *lm = to_line_mux(chip);\n\n\tguard(mutex)(&lm->lock);\n\n\tif (test_bit(offset, lm->dirs))\n\t\treturn GPIO_LINE_DIRECTION_IN;\n\n\treturn GPIO_LINE_DIRECTION_OUT;\n}\n\nstatic int gpio_line_mux_direction_input(struct gpio_chip *chip,\n\t\t\t\t\t unsigned int offset)\n{\n\tstruct gpio_line_mux *lm = to_line_mux(chip);\n\tint ret;\n\n\tguard(mutex)(&lm->lock);\n\n\tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n\tif (ret)\n\t\treturn ret;\n\n\tret = gpiod_direction_input(lm->gpiod);\n\tif (ret) {\n\t\tmux_control_deselect(lm->mux);\n\t\treturn ret;\n\t}\n\n\tset_bit(offset, lm->dirs);\n\tclear_bit(offset, lm->values);\n\n\treturn mux_control_deselect(lm->mux);\n}\n\nstatic int gpio_line_mux_direction_output(struct gpio_chip *chip,\n\t\t\t\t\t  unsigned int offset, int value)\n{\n\tstruct gpio_line_mux *lm = to_line_mux(chip);\n\tint ret;\n\n\tguard(mutex)(&lm->lock);\n\n\tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n\tif (ret)\n\t\treturn ret;\n\n\tret = gpiod_direction_output(lm->gpiod, value);\n\tif (ret) {\n\t\tmux_control_deselect(lm->mux);\n\t\treturn ret;\n\t}\n\n\tclear_bit(offset, lm->dirs);\n\t__assign_bit(offset, lm->values, value);\n\n\treturn mux_control_deselect(lm->mux);\n}\n\nstatic int gpio_line_mux_get(struct gpio_chip *chip, unsigned int offset)\n{\n\tstruct gpio_line_mux *lm = to_line_mux(chip);\n\tint ret, val;\n\n\tguard(mutex)(&lm->lock);\n\n\tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n\tif (ret)\n\t\treturn ret;\n\n\tif (!test_bit(offset, lm->dirs)) {\n\t\tret = gpiod_direction_input(lm->gpiod);\n\t\tif (ret) {\n\t\t\tmux_control_deselect(lm->mux);\n\t\t\treturn ret;\n\t\t}\n\t\tset_bit(offset, lm->dirs);\n\t}\n\n\tval = gpiod_get_value_cansleep(lm->gpiod);\n\n\tmux_control_deselect(lm->mux);\n\n\treturn val;\n}\n\nstatic int gpio_line_mux_set(struct gpio_chip *chip,\n\t\t\t     unsigned int offset, int value)\n{\n\tstruct gpio_line_mux *lm = to_line_mux(chip);\n\tint ret;\n\n\tguard(mutex)(&lm->lock);\n\n\tret = mux_control_select(lm->mux, lm->mux_states[offset]);\n\tif (ret)\n\t\treturn ret;\n\n\tif (test_bit(offset, lm->dirs)) {\n\t\tret = gpiod_direction_output(lm->gpiod, value);\n\t\tif (ret) {\n\t\t\tmux_control_deselect(lm->mux);\n\t\t\treturn ret;\n\t\t}\n\t\tclear_bit(offset, lm->dirs);\n\t} else {\n\t\tgpiod_set_value_cansleep(lm->gpiod, value);\n\t}\n\n\t__assign_bit(offset, lm->values, value);\n\n\treturn mux_control_deselect(lm->mux);\n}\n\nstatic const struct gpio_chip gpio_line_mux_chip_template = {\n\t.label\t\t\t= DRV_NAME,\n\t.owner\t\t\t= THIS_MODULE,\n\t.get_direction\t\t= gpio_line_mux_get_direction,\n\t.direction_input\t= gpio_line_mux_direction_input,\n\t.direction_output\t= gpio_line_mux_direction_output,\n\t.get\t\t\t= gpio_line_mux_get,\n\t.set\t\t\t= gpio_line_mux_set,\n\t.base\t\t\t= -1,\n\t.can_sleep\t\t= true,\n};\n\nstatic int gpio_line_mux_probe(struct platform_device *pdev)\n{\n\tstruct device *dev = &pdev->dev;\n\tstruct gpio_line_mux *lm;\n\tint ret, count;\n\n\tlm = devm_kzalloc(dev, sizeof(*lm), GFP_KERNEL);\n\tif (!lm)\n\t\treturn -ENOMEM;\n\n\tcount = device_property_count_u32(dev, \"gpio-line-mux-states\");\n\tif (count < 1)\n\t\treturn dev_err_probe(dev, count < 0 ? count : -EINVAL,\n\t\t\t\t     \"missing or empty gpio-line-mux-states\\n\");\n\n\tlm->mux_states = devm_kmalloc_array(dev, count, sizeof(u32),\n\t\t\t\t\t    GFP_KERNEL);\n\tif (!lm->mux_states)\n\t\treturn -ENOMEM;\n\n\tret = device_property_read_u32_array(dev, \"gpio-line-mux-states\",\n\t\t\t\t\t     lm->mux_states, count);\n\tif (ret)\n\t\treturn dev_err_probe(dev, ret,\n\t\t\t\t     \"failed to read gpio-line-mux-states\\n\");\n\n\tlm->ngpios = count;\n\n\tlm->mux = devm_mux_control_get(dev, NULL);\n\tif (IS_ERR(lm->mux))\n\t\treturn dev_err_probe(dev, PTR_ERR(lm->mux),\n\t\t\t\t     \"failed to get mux controller\\n\");\n\n\tlm->gpiod = devm_gpiod_get(dev, \"muxed\", GPIOD_ASIS);\n\tif (IS_ERR(lm->gpiod))\n\t\treturn dev_err_probe(dev, PTR_ERR(lm->gpiod),\n\t\t\t\t     \"failed to get muxed GPIO\\n\");\n\n\tif (gpiod_cansleep(lm->gpiod))\n\t\tdev_info(dev, \"underlying GPIO can sleep\\n\");\n\n\tlm->values = devm_bitmap_zalloc(dev, lm->ngpios, GFP_KERNEL);\n\tif (!lm->values)\n\t\treturn -ENOMEM;\n\n\tlm->dirs = devm_bitmap_zalloc(dev, lm->ngpios, GFP_KERNEL);\n\tif (!lm->dirs)\n\t\treturn -ENOMEM;\n\n\tbitmap_fill(lm->dirs, lm->ngpios);\n\n\tmutex_init(&lm->lock);\n\n\tlm->chip = gpio_line_mux_chip_template;\n\tlm->chip.parent = dev;\n\tlm->chip.ngpio = lm->ngpios;\n\n\tret = devm_gpiochip_add_data(dev, &lm->chip, lm);\n\tif (ret)\n\t\treturn dev_err_probe(dev, ret, \"failed to add gpio chip\\n\");\n\n\tplatform_set_drvdata(pdev, lm);\n\n\treturn 0;\n}\n\nstatic const struct of_device_id gpio_line_mux_dt_ids[] = {\n\t{ .compatible = \"gpio-line-mux\" },\n\t{}\n};\nMODULE_DEVICE_TABLE(of, gpio_line_mux_dt_ids);\n\nstatic struct platform_driver gpio_line_mux_driver = {\n\t.probe\t= gpio_line_mux_probe,\n\t.driver\t= {\n\t\t.name\t\t= DRV_NAME,\n\t\t.of_match_table\t= gpio_line_mux_dt_ids,\n\t},\n};\nmodule_platform_driver(gpio_line_mux_driver);\n\nMODULE_AUTHOR(\"OpenCode\");\nMODULE_DESCRIPTION(\"GPIO line mux driver - virtual GPIOs via mux controller\");\nMODULE_LICENSE(\"GPL\");","lineStart":1,"lineEnd":252,"totalLines":252,"truncated":false}},"title":"tmp/tmp.D9wEsGVJ2z/drivers/gpio/gpio-line-mux.c","time":{"start":1782186721256,"end":1782186721273}},"id":"prt_ef29b3f0b001KR26Qz2UkZ47J1","sessionID":"ses_10d73caccffeJObP2i94PboqoZ","messageID":"msg_ef29b3077001WQFuktRBgnCg7p"}}
